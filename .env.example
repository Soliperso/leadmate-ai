# LeadMate AI — client environment
# Copy to .env.local and fill in. Only VITE_-prefixed vars reach the browser.

# Supabase (auth + database)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PostHog (product analytics)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Stripe (publishable key only on the client)
VITE_STRIPE_PUBLISHABLE_KEY=

# Base URL of the backend / Supabase edge functions that hold the
# server-only secrets (OpenAI, Stripe secret key, Resend).
VITE_API_BASE_URL=

# ---------------------------------------------------------------------------
# SERVER-ONLY — never expose these to the browser. Set them in your Supabase
# edge function / backend environment, NOT with a VITE_ prefix.
#   OPENAI_API_KEY=
#   STRIPE_SECRET_KEY=
#   RESEND_API_KEY=
